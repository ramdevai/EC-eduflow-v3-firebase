# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Auth.js
AUTH_SECRET= # Run `npx auth secret` to generate

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron
CRON_SECRET=
# Google administrative refresh token (Requires Contacts and Calendar scopes)
GOOGLE_REFRESH_TOKEN=

# Email (SMTP + IMAP for Sent folder)
SMTP_HOST=mail.educompass.in
SMTP_PORT=587
SMTP_USER=your-email@educompass.in
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=EduCompass
IMAP_HOST=mail.educompass.in
IMAP_PORT=993
IMAP_SENT_FOLDER=INBOX.ECRM-sent
